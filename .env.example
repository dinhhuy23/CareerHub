# SQL Server for Docker + local app
MSSQL_SA_PASSWORD=sa-password
DB_HOST=localhost
DB_PORT=1433
DB_NAME=HireHubDB
DB_USER=sa
DB_PASSWORD=sa-password

# JWT config
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=86400
JWT_REFRESH_EXPIRES_IN=604800
