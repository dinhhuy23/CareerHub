<?xml version="1.0" encoding="UTF-8"?>
<web-app version="5.0"
         xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_5_0.xsd">

    <display-name>HireHubProject</display-name>

    <!-- Character Encoding Filter -->
    <filter>
        <filter-name>EncodingFilter</filter-name>
        <filter-class>filter.EncodingFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>EncodingFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- Authentication Filter - protects protected resources -->
    <filter>
        <filter-name>AuthenticationFilter</filter-name>
        <filter-class>filter.AuthenticationFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AuthenticationFilter</filter-name>
        <url-pattern>/user/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthenticationFilter</filter-name>
        <url-pattern>/employer/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthenticationFilter</filter-name>
        <url-pattern>/admin/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthenticationFilter</filter-name>
        <url-pattern>/job/apply</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthenticationFilter</filter-name>
        <url-pattern>/company/create</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthenticationFilter</filter-name>
        <url-pattern>/company/edit</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthenticationFilter</filter-name>
        <url-pattern>/uploads/cv/*</url-pattern>
    </filter-mapping>

    <!-- Admin Authorization Filter -->
    <filter>
        <filter-name>AdminAuthFilter</filter-name>
        <filter-class>filter.AuthorizationFilter</filter-class>
        <init-param>
            <param-name>allowedRoles</param-name>
            <param-value>ADMIN</param-value>
        </init-param>
    </filter>
    <filter-mapping>
        <filter-name>AdminAuthFilter</filter-name>
        <url-pattern>/admin/*</url-pattern>
    </filter-mapping>

    <!-- Employer Authorization Filter -->
    <filter>
        <filter-name>EmployerAuthFilter</filter-name>
        <filter-class>filter.AuthorizationFilter</filter-class>
        <init-param>
            <param-name>allowedRoles</param-name>
            <param-value>RECRUITER,ADMIN</param-value>
        </init-param>
    </filter>
    <filter-mapping>
        <filter-name>EmployerAuthFilter</filter-name>
        <url-pattern>/employer/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>EmployerAuthFilter</filter-name>
        <url-pattern>/company/create</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>EmployerAuthFilter</filter-name>
        <url-pattern>/company/edit</url-pattern>
    </filter-mapping>

    <!-- Candidate Authorization Filter -->
    <filter>
        <filter-name>CandidateAuthFilter</filter-name>
        <filter-class>filter.AuthorizationFilter</filter-class>
        <init-param>
            <param-name>allowedRoles</param-name>
            <param-value>CANDIDATE</param-value>
        </init-param>
    </filter>
    <filter-mapping>
        <filter-name>CandidateAuthFilter</filter-name>
        <url-pattern>/job/apply</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>CandidateAuthFilter</filter-name>
        <url-pattern>/user/my-applications</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>CandidateAuthFilter</filter-name>
        <url-pattern>/user/save-job</url-pattern>
    </filter-mapping>

    <!-- Session Config -->
    <session-config>
        <session-timeout>1440</session-timeout> <!-- 24 hours -->
    </session-config>

    <!-- Welcome File -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- Error Pages -->
    <error-page>
        <error-code>404</error-code>
        <location>/error/404.jsp</location>
    </error-page>
    <error-page>
        <error-code>403</error-code>
        <location>/error/403.jsp</location>
    </error-page>
    <error-page>
        <error-code>500</error-code>
        <location>/error/500.jsp</location>
    </error-page>
</web-app>
